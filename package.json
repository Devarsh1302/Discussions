{
  "name": "insight-discussions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "db:setup": "tsx server/scripts/runSchema.ts",
    "build": "vite build && tsup server/index.ts --format esm --platform node --out-dir dist/server --clean --external vite",
    "start": "cross-env NODE_ENV=production node dist/server/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/manrope": "^5.1.1",
    "@fontsource/space-grotesk": "^5.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.1.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
